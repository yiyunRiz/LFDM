{
  "name": "lfdm-diffusion-sampling",
  "phase": "val",
  "distributed": false,
  "gpu_ids": [0],
  "path": {
    "log": "logs",
    "tb_logger": "tb_logger",
    "results": "results",
    "checkpoint": "checkpoint",
    "resume_state": "checkpoints/diffusion_backbone"
  },
  "datasets": {
    "val": {
      "name": "sampling",
      "resolution": 256,
      "data_len": 10
    }
  },
  "model": {
    "which_model_G": "sr3",
    "finetune_norm": false,
    "unet": {
      "in_channel": 3,
      "out_channel": 3,
      "inner_channel": 128,
      "channel_multiplier": [1, 2, 4, 8, 8],
      "attn_res": [16],
      "res_blocks": 2,
      "dropout": 0.2
    },
    "beta_schedule": {
      "train": {
        "schedule": "cosine",
        "n_timestep": 2000,
        "linear_start": 0.000001,
        "linear_end": 0.01
      },
      "val": {
        "schedule": "cosine",
        "n_timestep": 2000,
        "linear_start": 0.000001,
        "linear_end": 0.01
      }
    },
    "diffusion": {
      "image_size": 256,
      "channels": 3,
      "loss": "l2",
      "conditional": false
    }
  },
  "train": {
    "optimizer": {
      "type": "adamw",
      "lr": 0.00001
    }
  },
  "wandb": {
    "project": "LFDM-diffusion"
  }
}
